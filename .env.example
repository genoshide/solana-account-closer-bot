# ============================================================
#   Genoshide Token Account Closer Bot - Configuration File
#   Copy this file to .env and fill in your values.
# ============================================================

# ----------------------------------------------------------
# SOLANA RPC ENDPOINT
# Use a reliable RPC provider (Helius, QuickNode, etc.)
# ----------------------------------------------------------
RPC_URL=https://api.mainnet-beta.solana.com

# ----------------------------------------------------------
# PRIVATE KEYS (Multi-Account Support)
# Separate multiple base58 private keys with commas.
# Example: PRIVATE_KEYS=KEY1,KEY2,KEY3
# ----------------------------------------------------------
PRIVATE_KEYS=YOUR_BASE58_PRIVATE_KEY_1,YOUR_BASE58_PRIVATE_KEY_2

# ----------------------------------------------------------
# LOOP SETTINGS
# CHECK_INTERVAL: Delay (in seconds) between each scan cycle.
# ----------------------------------------------------------
CHECK_INTERVAL=5

# ----------------------------------------------------------
# THREADING SETTINGS
# MAX_THREADS: Maximum number of concurrent account workers.
# Should not exceed the number of accounts in PRIVATE_KEYS.
# ----------------------------------------------------------
MAX_THREADS=10
