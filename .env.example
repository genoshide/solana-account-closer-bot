# ============================================================
#   Genoshide Token Account Closer Bot - Configuration File
#   Copy this file to .env and fill in your values.
#   Private keys are loaded from private_key.txt (not here).
# ============================================================

# ----------------------------------------------------------
# SOLANA RPC ENDPOINT
# Use a reliable RPC provider (Helius, QuickNode, etc.)
# ----------------------------------------------------------
RPC_URL=https://api.mainnet-beta.solana.com

# ----------------------------------------------------------
# DESTINATION WALLET
# Required ONLY when private_key.txt contains more than 1 key.
# All rent SOL reclaimed from closed accounts will be sent here.
# If private_key.txt has only 1 key, this value is ignored.
# ----------------------------------------------------------
DESTINATION_WALLET=YOUR_DESTINATION_WALLET_PUBKEY

# ----------------------------------------------------------
# LOOP SETTINGS
# CHECK_INTERVAL: Delay (in seconds) between each scan cycle.
# ----------------------------------------------------------
CHECK_INTERVAL=5

# ----------------------------------------------------------
# THREADING SETTINGS
# MAX_THREADS: Maximum number of concurrent account workers.
# Should not exceed the number of keys in private_key.txt.
# ----------------------------------------------------------
MAX_THREADS=10
